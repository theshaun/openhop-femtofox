// Allow the repeater service user to restart its own systemd unit
// without password. The repeater app calls `systemctl restart
// openhop-repeater` on config changes; without this rule, polkit
// denies the action and the app falls back to sudo, which fails
// under the unit's ProtectSystem=strict (no writable /run/sudo/ts,
// and no NOPASSWD rule exists for the repeater user).
//
// Scoped tightly: only subject.user == "repeater", only the
// openhop-repeater.service unit, only manage-units actions.
polkit.addRule(function(action, subject) {
    if (action.id == "org.freedesktop.systemd1.manage-units" &&
        action.lookup("unit") == "openhop-repeater.service" &&
        subject.user == "repeater") {
        return polkit.Result.YES;
    }
});
